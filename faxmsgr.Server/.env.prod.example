# =============================================================================
# Шаблон переменных окружения для PRODUCTION.
# Скопируйте файл: cp .env.prod.example .env
# Заполните ВСЕ значения перед запуском.
# НИКОГДА не коммитьте заполненный .env в репозиторий.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — основная база данных
# -----------------------------------------------------------------------------
FAX_PG_DB=faxmsgr
FAX_PG_USER=faxmsgr
FAX_PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# PostgreSQL — архивная база данных (Закон Яровой)
# -----------------------------------------------------------------------------
FAX_PG_ARCHIVE_DB=faxmsgr_archive
FAX_PG_ARCHIVE_USER=faxmsgr_archive
FAX_PG_ARCHIVE_PASSWORD=CHANGE_ME_STRONG_ARCHIVE_PASSWORD

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
FAX_REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# MinIO (S3-совместимое хранилище медиафайлов)
# -----------------------------------------------------------------------------
FAX_MINIO_USER=CHANGE_ME_MINIO_USER
FAX_MINIO_PASSWORD=CHANGE_ME_MINIO_PASSWORD_MIN_8_CHARS

# Имя bucket — можно оставить без изменений
FAX_S3_BUCKET=faxmsgr-media

# -----------------------------------------------------------------------------
# Go-сервер
# -----------------------------------------------------------------------------
# JWT-секрет: сгенерируйте командой: openssl rand -hex 32
FAX_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32

# Адрес, на котором слушает сервер (менять не нужно при работе за Nginx)
FAX_SERVER_ADDR=:8080
